      "title": "Statistiche Generali",
      "type": "row"
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 52 },
      "id": 50,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Giorni Tracciati",
      "type": "stat",
      "targets": [{ "rawQueryText": "SELECT COUNT(DISTINCT m.date) AS giorni FROM meal m", "queryType": "table", "refId": "A" }]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 52 },
      "id": 51,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Pasti Totali",
      "type": "stat",
      "targets": [{ "rawQueryText": "SELECT COUNT(*) AS pasti FROM meal", "queryType": "table", "refId": "A" }]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "kcal" } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 52 },
      "id": 54,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Media Calorie/Giorno",
      "type": "stat",
      "targets": [{ "rawQueryText": "SELECT ROUND(AVG(daily_cal), 0) AS media FROM (SELECT SUM(f.calories) AS daily_cal FROM meal m JOIN food f ON f.meal_id = m.id WHERE f.calories IS NOT NULL GROUP BY m.date)", "queryType": "table", "refId": "A" }]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 52 },
      "id": 55,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Media Pasti/Giorno",
      "type": "stat",
      "targets": [{ "rawQueryText": "SELECT ROUND(CAST(COUNT(*) AS REAL) / COUNT(DISTINCT m.date), 1) AS media FROM meal m", "queryType": "table", "refId": "A" }]
