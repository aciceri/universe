      "title": "Macronutrienti",
      "type": "row"
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "grammi",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "g"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "proteine" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "carboidrati" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "grassi" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 25 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Macronutrienti Giornalieri",
      "type": "timeseries",
      "targets": [
        {
          "rawQueryText": "SELECT CAST(strftime('%s', m.date || 'T12:00:00Z') AS INTEGER) AS time, ROUND(SUM(f.protein), 1) AS proteine, ROUND(SUM(f.carbs), 1) AS carboidrati, ROUND(SUM(f.fats), 1) AS grassi FROM meal m JOIN food f ON f.meal_id = m.id WHERE m.date >= date('now', '-30 days') GROUP BY m.date ORDER BY m.date",
          "queryType": "time_series",
          "timeColumns": ["time"],
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "g"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Proteine" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Carboidrati" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Grassi" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 25 },
      "id": 21,
      "options": {
        "displayLabels": ["percent"],
        "legend": { "displayMode": "table", "placement": "bottom", "values": ["value"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "tooltip": { "mode": "single" }
      },
      "title": "Ripartizione Macro (Oggi)",
      "type": "piechart",
      "targets": [
        {
          "rawQueryText": "SELECT COALESCE(SUM(f.protein), 0) AS Proteine, COALESCE(SUM(f.carbs), 0) AS Carboidrati, COALESCE(SUM(f.fats), 0) AS Grassi FROM meal m JOIN food f ON f.meal_id = m.id WHERE m.date = date('now')",
          "queryType": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "grammi",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "g"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "fibre" },
