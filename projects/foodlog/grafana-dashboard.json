          "unit": "kcal"
        }
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 43 },
      "id": 31,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Calorie per Pasto (Ultimi 7 Giorni)",
      "type": "timeseries",
      "targets": [
        {
          "rawQueryText": "SELECT CAST(strftime('%s', m.date || 'T12:00:00Z') AS INTEGER) AS time, m.meal_type AS metric, SUM(f.calories) AS value FROM meal m JOIN food f ON f.meal_id = m.id WHERE f.calories IS NOT NULL AND m.date >= date('now', '-7 days') GROUP BY m.date, m.meal_type ORDER BY m.date",
          "queryType": "time_series",
          "timeColumns": ["time"],
