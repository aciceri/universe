      "targets": [
        {
          "rawQueryText": "SELECT CAST(strftime('%s', m.date || 'T12:00:00Z') AS INTEGER) AS time, ROUND(SUM(f.fiber), 1) AS fibre, ROUND(SUM(f.sugars), 1) AS zuccheri FROM meal m JOIN food f ON f.meal_id = m.id WHERE m.date >= date('now', '-30 days') GROUP BY m.date ORDER BY m.date",
          "queryType": "time_series",
          "timeColumns": ["time"],
          "refId": "A"
