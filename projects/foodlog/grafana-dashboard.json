      "targets": [
        {
          "rawQueryText": "SELECT m.meal_type AS metric, SUM(f.calories) AS value FROM meal m JOIN food f ON f.meal_id = m.id WHERE f.calories IS NOT NULL GROUP BY m.meal_type ORDER BY value DESC",
          "queryType": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "kcal",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "group": "A", "mode": "normal" }
