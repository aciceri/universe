    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Riepilogo Oggi",
      "type": "row"
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1200 },
              { "color": "green", "value": 1800 },
              { "color": "orange", "value": 2500 },
              { "color": "red", "value": 3000 }
            ]
          },
          "unit": "kcal"
        }
      },
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Calorie Oggi",
      "type": "stat",
      "targets": [
        {
          "rawQueryText": "SELECT COALESCE(SUM(f.calories), 0) AS calories FROM meal m JOIN food f ON f.meal_id = m.id WHERE m.date = date('now')",
          "queryType": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 100 }
            ]
          },
          "unit": "g"
        }
      },
      "gridPos": { "h": 5, "w": 5, "x": 5, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Proteine Oggi",
      "type": "stat",
      "targets": [
        {
          "rawQueryText": "SELECT COALESCE(SUM(f.protein), 0) AS proteine FROM meal m JOIN food f ON f.meal_id = m.id WHERE m.date = date('now')",
          "queryType": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 150 },
