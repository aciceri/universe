            ]
          },
          "unit": "g"
        }
      },
      "gridPos": { "h": 5, "w": 5, "x": 10, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Carboidrati Oggi",
      "type": "stat",
      "targets": [
        {
          "rawQueryText": "SELECT COALESCE(SUM(f.carbs), 0) AS carboidrati FROM meal m JOIN food f ON f.meal_id = m.id WHERE m.date = date('now')",
          "queryType": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 40 },
              { "color": "orange", "value": 80 }
            ]
          },
          "unit": "g"
        }
      },
      "gridPos": { "h": 5, "w": 5, "x": 15, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Grassi Oggi",
      "type": "stat",
      "targets": [
        {
          "rawQueryText": "SELECT COALESCE(SUM(f.fats), 0) AS grassi FROM meal m JOIN food f ON f.meal_id = m.id WHERE m.date = date('now')",
          "queryType": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "semi-dark-green", "value": null },
              { "color": "green", "value": 20 }
            ]
          },
          "unit": "g"
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Fibre Oggi",
      "type": "stat",
      "targets": [
        {
          "rawQueryText": "SELECT COALESCE(SUM(f.fiber), 0) AS fibre FROM meal m JOIN food f ON f.meal_id = m.id WHERE m.date = date('now')",
          "queryType": "table",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "title": "Andamento Calorie",
      "type": "row"
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "kcal",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 2200 }
            ]
          },
          "unit": "kcal"
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 7 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["mean", "max", "min"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Calorie Giornaliere per Pasto",
      "type": "timeseries",
      "targets": [
        {
          "rawQueryText": "SELECT CAST(strftime('%s', m.date || 'T12:00:00Z') AS INTEGER) AS time, m.meal_type AS metric, SUM(f.calories) AS value FROM meal m JOIN food f ON f.meal_id = m.id WHERE f.calories IS NOT NULL AND m.date >= date('now', '-30 days') GROUP BY m.date, m.meal_type ORDER BY m.date",
          "queryType": "time_series",
          "timeColumns": ["time"],
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_FOODLOG}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "kcal",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 6,
            "showPoints": "always",
            "spanNulls": true
          },
          "unit": "kcal"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Calorie Totali Giornaliere (Trend)",
      "type": "timeseries",
      "targets": [
        {
          "rawQueryText": "SELECT CAST(strftime('%s', m.date || 'T12:00:00Z') AS INTEGER) AS time, SUM(f.calories) AS calories FROM meal m JOIN food f ON f.meal_id = m.id WHERE f.calories IS NOT NULL AND m.date >= date('now', '-90 days') GROUP BY m.date ORDER BY m.date",
          "queryType": "time_series",
          "timeColumns": ["time"],
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
